@page "/patient/{Id:int}"
@rendermode InteractiveServer

@using MudBlazor
@using DCI_Domain.Entities;
@using DCI_Domain.Enums;

@inject DCI_app.Services.PatientService PatientService
@inject DCI_app.Services.MedicalHistoryService HistoryService
@inject DCI_app.Services.ConsultationService ConsultationService
@inject DCI_app.Services.DoctorService DoctorService
@inject DCI_app.Services.MedicationService MedicationService
@inject DCI_app.Services.PrescriptionService PrescriptionService
@inject NavigationManager Nav
@inject PrescriptionPdfService PdfService
@inject IJSRuntime JS

<MudContainer Class="mt-6">

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_patient is null)
    {
        <MudAlert Severity="Severity.Error">
            Patient introuvable
        </MudAlert>
    }
    else
    {
        <!-- ================= HEADER ================= -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Nav.NavigateTo("/patients"))">
                Retour
            </MudButton>

            <MudText Typo="Typo.h4" Color="Color.Primary">
                👤 @_patient.LastName, @_patient.FirstName
            </MudText>

        </MudStack>

        <MudDivider Class="my-3" />

        <!-- ================= TABS ================= -->
        <MudTabs Elevation="2">

            <!-- ================= INFOS ================= -->
            <MudTabPanel Text="👤 Infos">

                <MudPaper Class="pa-4 mt-3">

                    <MudText><b>Téléphone :</b> @_patient.Phone</MudText>
                    <MudText><b>Adresse :</b> @_patient.Address</MudText>
                    <MudText><b>Date naissance :</b> @_patient.BirthDate.ToShortDateString()</MudText>

                </MudPaper>

            </MudTabPanel>

            <!-- ================= CONSULTATIONS ================= -->
            <MudTabPanel Text="🩺 Consultations">

                <MudPaper Class="pa-4 mt-3">

                    <MudText Typo="Typo.h6">Nouvelle consultation</MudText>

                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="int?" @bind-Value="_newConsultation.DoctorId" Label="Médecin">
                                @foreach (var doc in _doctors)
                                {
                                    <MudSelectItem Value="@doc.Id">
                                        @doc.FullName
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.Symptoms" Label="Symptômes" Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.Diagnosis" Label="Diagnostic" Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.TreatmentPlan" Label="Traitement" Lines="2" />
                        </MudItem>

                    </MudGrid>

                    <MudButton Class="mt-3"
                               Color="Color.Primary"
                               OnClick="AddConsultation">
                        ➕ Ajouter consultation
                    </MudButton>

                </MudPaper>

                <MudTable Items="_consultations" Hover="true" Class="mt-4">

                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Médecin</MudTh>
                        <MudTh>Diagnostic</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>@context.Date.ToShortDateString()</MudTd>
                        <MudTd>@GetDoctorName(context.DoctorId)</MudTd>
                        <MudTd>@context.Diagnosis</MudTd>
                    </RowTemplate>

                </MudTable>

            </MudTabPanel>

            <!-- ================= HISTORIQUE ================= -->
            <MudTabPanel Text="🧾 Historique">

                <MudTable Items="_histories" Hover="true">

                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Diagnostic</MudTh>
                        <MudTh>Traitement</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>@context.Date.ToShortDateString()</MudTd>
                        <MudTd>@context.Diagnosis</MudTd>
                        <MudTd>@context.Treatment</MudTd>
                    </RowTemplate>

                </MudTable>

            </MudTabPanel>

            <!-- ================= PRESCRIPTION ================= -->
            <MudTabPanel Text="💊 Prescription">

                <MudPaper Class="pa-4 mt-3">

                    <MudText Typo="Typo.h6">Nouvelle prescription</MudText>

                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" @bind-Value="_newItem.MedicationId" Label="Médicament">
                                @foreach (var med in _medications)
                                {
                                    <MudSelectItem Value="@med.Id">
                                        @med.Name - @med.Strength
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_newItem.Dosage" Label="Dosage" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_newItem.Frequency" Label="Fréquence" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_newItem.Duration" Label="Durée" />
                        </MudItem>

                    </MudGrid>

                    <MudButton Class="mt-3"
                               Color="Color.Primary"
                               OnClick="AddMedication">
                        ➕ Ajouter médicament
                    </MudButton>

                </MudPaper>

                <MudTable Items="_items" Hover="true" Class="mt-4">

                    <HeaderContent>
                        <MudTh>Médicament</MudTh>
                        <MudTh>Dosage</MudTh>
                        <MudTh>Fréquence</MudTh>
                        <MudTh>Durée</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>
                            @(_medications.FirstOrDefault(m => m.Id == context.MedicationId)?.Name)
                        </MudTd>
                        <MudTd>@context.Dosage</MudTd>
                        <MudTd>@context.Frequency</MudTd>
                        <MudTd>@context.Duration</MudTd>

                        <MudTd>
                            <MudButton Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => RemoveMedication(context))">
                                Supprimer
                            </MudButton>
                        </MudTd>
                    </RowTemplate>

                </MudTable>

                <MudButton Class="mt-3"
                           Color="Color.Success"
                           OnClick="SavePrescription">
                    💾 Enregistrer prescription
                </MudButton>
                <MudButton Color="Color.Info"
                           Variant="Variant.Filled"
                           OnClick="DownloadPdf">
                    📄 Télécharger ordonnance PDF
                </MudButton>

            </MudTabPanel>

        </MudTabs>
    }

</MudContainer>

@code {

    [Parameter] public int Id { get; set; }

    private bool _loading = true;

    private Patient? _patient;
    private List<MedicalHistory> _histories = new();
    private List<Consultation> _consultations = new();
    private List<Doctor> _doctors = new();
    private List<Medication> _medications = new();

    private Consultation _newConsultation = new();

    private List<PrescriptionItem> _items = new();
    private PrescriptionItem _newItem = new();

    protected override async Task OnInitializedAsync()
    {
        _patient = await PatientService.GetByIdAsync(Id);

        if (_patient != null)
        {
            _histories = await HistoryService.GetByPatientIdAsync(Id);
            _consultations = await ConsultationService.GetByPatientIdAsync(Id);
            _doctors = await DoctorService.GetAllAsync();
            _medications = await MedicationService.GetAllAsync();
        }

        _loading = false;
    }

    private async Task AddConsultation()
    {
        _newConsultation.PatientId = Id;
        await ConsultationService.AddAsync(_newConsultation);

        _newConsultation = new Consultation();
        _consultations = await ConsultationService.GetByPatientIdAsync(Id);
    }

    private string GetDoctorName(int? id)
        => _doctors.FirstOrDefault(d => d.Id == id)?.FullName ?? "N/A";

    private void AddMedication()
    {
        if (_newItem.MedicationId == 0) return;

        var med = _medications.FirstOrDefault(m => m.Id == _newItem.MedicationId);

        _items.Add(new PrescriptionItem
        {
            MedicationId = _newItem.MedicationId,
            MedicationName = med?.Name ?? "",
            Dosage = _newItem.Dosage,
            Frequency = _newItem.Frequency,
            Duration = _newItem.Duration
        });

        _newItem = new PrescriptionItem();
    }

    private void RemoveMedication(PrescriptionItem item)
        => _items.Remove(item);

    private async Task SavePrescription()
    {
        var prescription = new Prescription
        {
            PatientId = Id,
            ConsultationId = _consultations.LastOrDefault()?.Id ?? 0,
            DoctorId = _consultations.LastOrDefault()?.DoctorId ?? 0,
            CreatedAt = DateTime.Now,
            Items = _items
        };

        await PrescriptionService.AddAsync(prescription);

        _items.Clear();
    }

    private async Task DownloadPdf()
    {
        var prescription = new Prescription
        {
            CreatedAt = DateTime.Now,
            Items = _items
        };

        var pdfBytes = PdfService.Generate(prescription, _patient!);

        var base64 = Convert.ToBase64String(pdfBytes);

        await JS.InvokeVoidAsync("downloadPdf", base64, "ordonnance.pdf");
    }
}