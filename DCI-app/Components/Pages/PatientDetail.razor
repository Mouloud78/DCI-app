@page "/patient/{Id:int}"
@rendermode InteractiveServer

@using MudBlazor
@using DCI_app.Models

@inject DCI_app.Services.PatientService PatientService
@inject DCI_app.Services.MedicalHistoryService HistoryService
@inject DCI_app.Services.ConsultationService ConsultationService
@inject DCI_app.Services.DoctorService DoctorService
@inject NavigationManager Nav


<MudContainer Class="mt-6">

    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_patient is null)
    {
        <MudAlert Severity="Severity.Error">
            Patient introuvable
        </MudAlert>
    }
    else
    {

        <!-- ================= HEADER ================= -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Nav.NavigateTo("/patients"))">
                Retour
            </MudButton>

            <MudText Typo="Typo.h4" Color="Color.Primary">
                👤 @_patient.FullName
            </MudText>

        </MudStack>

        <MudDivider Class="my-3" />

        <!-- ================= TABS ================= -->
        <MudTabs Elevation="2">

            <!-- ================= INFO PATIENT ================= -->
            <MudTabPanel Text="👤 Infos">

                <MudPaper Class="pa-4 mt-3">

                    <MudText><b>Téléphone :</b> @_patient.Phone</MudText>
                    <MudText><b>Adresse :</b> @_patient.Address</MudText>
                    <MudText><b>Date naissance :</b> @_patient.DateOfBirth.ToShortDateString()</MudText>

                </MudPaper>

            </MudTabPanel>

            <!-- ================= CONSULTATIONS ================= -->
            <MudTabPanel Text="🩺 Consultations">

                <!-- FORM -->
                <MudPaper Class="pa-4 mt-3">

                    <MudText Typo="Typo.h6">Nouvelle consultation</MudText>

                    <MudGrid>

                        <MudItem xs="12" sm="6">
                            <MudSelect T="int?" @bind-Value="_newConsultation.DoctorId" Label="Médecin">

                                @foreach (var doc in _doctors)
                                {
                                    <MudSelectItem T="int?" Value="@doc.Id">
                                        @doc.FullName - @doc.Specialty
                                    </MudSelectItem>
                                }

                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.Symptoms"
                                          Label="Symptômes"
                                          Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.ClinicalExam"
                                          Label="Examen clinique"
                                          Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.Diagnosis"
                                          Label="Diagnostic"
                                          Lines="2" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newConsultation.TreatmentPlan"
                                          Label="Traitement"
                                          Lines="2" />
                        </MudItem>

                    </MudGrid>

                    <MudButton Class="mt-3"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               OnClick="AddConsultation">
                        ➕ Ajouter consultation
                    </MudButton>

                </MudPaper>

                <!-- LISTE -->
                <MudPaper Class="pa-4 mt-4">

                    <MudText Typo="Typo.h6">Historique consultations</MudText>

                    <MudTable Items="_consultations" Hover="true">

                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Médecin</MudTh>
                            <MudTh>Diagnostic</MudTh>
                            <MudTh>Statut</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd>@context.Date.ToShortDateString()</MudTd>
                            <MudTd>@GetDoctorName(context.DoctorId)</MudTd>
                            <MudTd>@context.Diagnosis</MudTd>
                            <MudTd>@context.Status</MudTd>
                        </RowTemplate>

                    </MudTable>

                </MudPaper>

            </MudTabPanel>

            <!-- ================= HISTORIQUE ================= -->
            <MudTabPanel Text="🧾 Historique médical">

                <MudPaper Class="pa-4 mt-3">

                    @if (!_histories.Any())
                    {
                        <MudText>Aucun historique</MudText>
                    }
                    else
                    {
                        <MudTable Items="_histories">

                            <HeaderContent>
                                <MudTh>Date</MudTh>
                                <MudTh>Diagnostic</MudTh>
                                <MudTh>Traitement</MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd>@context.Date.ToShortDateString()</MudTd>
                                <MudTd>@context.Diagnosis</MudTd>
                                <MudTd>@context.Treatment</MudTd>
                            </RowTemplate>

                        </MudTable>
                    }

                </MudPaper>

            </MudTabPanel>

        </MudTabs>

    }

</MudContainer>
@code {

    [Parameter] public int Id { get; set; }

    private bool _loading = true;

    private Patient? _patient;
    private List<MedicalHistory> _histories = new();
    private List<Consultation> _consultations = new();
    private List<Doctor> _doctors = new();

    private Consultation _newConsultation = new();

    protected override async Task OnInitializedAsync()
    {
        _patient = await PatientService.GetByIdAsync(Id);

        if (_patient != null)
        {
            _histories = await HistoryService.GetByPatientIdAsync(Id);
            _consultations = await ConsultationService.GetByPatientIdAsync(Id);
            _doctors = await DoctorService.GetAllAsync();
        }

        _loading = false;
    }

    private async Task AddConsultation()
    {
        _newConsultation.PatientId = Id;

        await ConsultationService.AddAsync(_newConsultation);

        _newConsultation = new Consultation();

        _consultations = await ConsultationService.GetByPatientIdAsync(Id);
    }

    private string GetDoctorName(int? doctorId)
    {
        return _doctors.FirstOrDefault(d => d.Id == doctorId)?.FullName ?? "N/A";
    }
}