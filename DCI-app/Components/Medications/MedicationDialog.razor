@using DCI_Domain.Entities
@using DCI_app.Services
@using MudBlazor

@inject MedicationService MedicationService

<MudDialog>

    <DialogContent>

        <MudText Typo="Typo.h6">
            Médicament
        </MudText>

        <MudTextField T="string"
                      Label="Nom commercial"
                      @bind-Value="Medication.Name" />

        <MudTextField T="string"
                      Label="DCI"
                      @bind-Value="Medication.GenericName" />

        <MudTextField T="string"
                      Label="Dosage"
                      @bind-Value="Medication.Strength" />

        <MudTextField T="string"
                      Label="Forme"
                      @bind-Value="Medication.Form" />

        <MudTextField T="string"
                      Label="Voie"
                      @bind-Value="Medication.Route" />

        <MudTextField T="string"
                      Label="Fabricant"
                      @bind-Value="Medication.Manufacturer" />

        <MudTextField T="string"
                      Label="Code"
                      @bind-Value="Medication.Code" />

        <MudCheckBox T="bool"
                     Label="Disponible"
                     @bind-Value="Medication.IsAvailable" />

    </DialogContent>

    <DialogActions>

        <MudButton OnClick="Cancel">

            Annuler

        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save">

            Enregistrer

        </MudButton>

    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Medication Medication { get; set; } = new();

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        if (Medication.Id == 0)
        {
            await MedicationService.AddAsync(Medication);
        }
        else
        {
            await MedicationService.UpdateAsync(Medication);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

}